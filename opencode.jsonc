{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    // https://github.com/ChromeDevTools/chrome-devtools-mcp/
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--autoConnect", "--browserUrl=http://127.0.0.1:9222"],
      "enabled": true
    }
  }
}